# Port this service listens on
PORT=3500
# RabbitMQ — same instance as detect_plate_service
AMQP_URL=amqp://guest:guest@localhost:5672/
# Durable queue name (unique to this consumer)
AMQP_QUEUE=gantry-interface.plate-events
# detect_plate_service base URL
DETECT_SERVICE_URL=http://localhost:8081
# Your arrival composite/API endpoint
# Called with POST { plate: "SBA1234A" } on every detected plate
ARRIVAL_API_URL=http://localhost:5000/arrival

# --- Model ---
MODEL_PATH=plate_model.pt
DETECT_CONF=0.5
USE_GPU=true
# --- Server ---
HOST=0.0.0.0
PORT=8000
# --- Gantry identity (included in every RabbitMQ event) ---
GANTRY_ID=gantry-01
HF_TOKEN=abc
# --- Camera stream ---
# RTSP or MJPEG URL.  Leave empty to disable auto-start on boot.
# You can always start/stop the stream at runtime via the API:
#   POST /stream/start  {"stream_url": "http://192.168.1.5:8080/video"}
#   POST /stream/stop
#
# Examples:
#   STREAM_URL=http://192.168.1.5:8080/video            # IP Webcam (Android)
STREAM_URL=http://192.168.50.224:8080/video

# Seconds between processing frames (lower = faster detection, higher CPU)
PROCESS_INTERVAL=6.0

# Seconds before the same plate text can trigger another event
COOLDOWN_S=30.0

# --- RabbitMQ ---
# If RabbitMQ is unreachable at startup, the service runs in log-only mode.
# Events are logged to stdout but not published.
AMQP_URL=abc
# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=10

# ── Streamer ───────────────────────────────────────────────────────────────────

# Camera index — 0 is usually the first USB webcam
CAMERA_INDEX=0

# Where the plate detection service is running
DETECT_URL=http://localhost:3001/api/plate/detect

# Where confirmed plates get sent
# Replace with your real Drive-Thru Order Orchestrator endpoint when ready
WEBHOOK_URL=http://localhost:9000/gantry/webhook

# Seconds before the same plate can fire the webhook again
# Prevents the same car triggering 20 times while waiting at the barrier
COOLDOWN_SECONDS=10

# Minimum contour area (px²) to count as motion
# Increase if you're getting false triggers from shadows or small animals
# Decrease if the car is far from the camera and appears small
MOTION_AREA_MIN=8000

# JPEG quality sent to the detect service (lower = faster network, worse OCR)
JPEG_QUALITY=85

# How often (ms) to call detect while motion is active
# TrOCR takes ~300-800ms on CPU so going below 500 just queues up requests
POLL_INTERVAL_MS=500
